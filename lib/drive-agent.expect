#!/usr/bin/expect -f

if {$argc < 1} {
    puts stderr "usage: drive-agent.expect <binary> [message]"
    exit 2
}

set bin [lindex $argv 0]
set message "Hey!"
if {$argc >= 2} {
    set message [lindex $argv 1]
}

set idle_secs 4
set hard_cap 90

set raw_output 0
if {[info exists env(RAW_AGENT_OUTPUT)] && $env(RAW_AGENT_OUTPUT) eq "1"} {
    set raw_output 1
}
log_user $raw_output

if {[catch {spawn -noecho $bin $message} err]} {
    puts stderr "failed to spawn $bin: $err"
    exit 3
}

set pid [exp_pid]

sleep 2

set start [clock seconds]
set timeout $idle_secs
expect {
    -re ".+" {
        if {[expr {[clock seconds] - $start}] < $hard_cap} {
            exp_continue
        }
    }
    timeout { }
}

catch { send "\x03" } _
sleep 0.5
catch { send "\x03" } _

set timeout 5
catch { expect eof } _
catch { exec kill -TERM $pid } _
catch { exec kill -KILL $pid } _
